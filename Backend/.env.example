# Gemini API (required for knowledge-graph chat synthesis and PR extraction)
GEMINI_API_KEY=your_gemini_api_key
# Quotas are per Google Cloud / AI Studio project — rotating API keys in the same project does not raise limits.
# Ingest defaults: 1 PR at a time + ~3.5s gap (see GEMINI_INGEST_*) so free-tier RPM is not blown by chat + graph together.
# GEMINI_INGEST_CONCURRENCY=1
# GEMINI_INGEST_DELAY_MS=3500
# Text generation default: extraction, narratives, explanations, and chat (free tier: gemini-2.5-flash-lite)
# GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
# PR comment explanations (POST /api/explain) — default gemini-2.5-flash
# GEMINI_EXPLAIN_MODEL=gemini-2.5-flash
# Max wait for /api/explain Gemini call in ms (default 25000; min 5000, max 120000)
# GEMINI_EXPLAIN_TIMEOUT_MS=25000
# Demo: skip GitHub + Gemini; only return pre-seeded explanations_cache (npm run seed)
# DEMO_MODE=true
# Optional: override only the knowledge-graph chat endpoint
# GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# Optional: comma-separated fallbacks when chat hits 429 (separate per-model quotas on free tier)
# GEMINI_CHAT_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
# Embeddings for ingest + chat vector tier (comma-separated). Default tries text-embedding-004, embedding-001, gemini-embedding-001 (v1 API compatibility).
# Atlas vector index numDimensions must match the model output (often 768 — set in Atlas UI).
# GEMINI_EMBEDDING_MODELS=text-embedding-004,embedding-001

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gitlore

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Use frontend origin when Vite proxies /auth (pnpm run dev on port 8080):
GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
# Optional explicit redirect target; otherwise derived from GITHUB_CALLBACK_URL origin:
# FRONTEND_URL=http://localhost:8080

# Session
SESSION_SECRET=your_random_64_char_secret_string_here

# Server
PORT=3001
NODE_ENV=development

# CORS (browser + credentials) — comma-separated origins; must include your Vite dev URL
# CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Chrome extension + backend (optional — only if the extension calls this API with cookies / Bearer)
# Exact chrome-extension:// origins allowed for credentialed CORS (not a wildcard).
# CHROME_EXTENSION_CORS_ORIGINS=chrome-extension://YOUR_EXTENSION_ID_HERE
# Exact OAuth callback URLs allowed for POST /auth/github/extension/token (server exchanges code with client secret).
# Comma-separated; trailing slashes optional (normalized). Must match GitHub OAuth app callback URLs.
# GITHUB_EXTENSION_REDIRECT_URIS=https://YOUR_EXTENSION_ID.chromiumapp.org/

# Optional - for fallback
GITHUB_PAT=your_github_personal_access_token

# ElevenLabs (optional) — Live repo “Listen / voice agent”
# Copy these lines into Backend/.env (this example file is not loaded at runtime).
# ELEVENLABS_API_KEY=
# Free tier: use a PREMADE voice ID for TTS API (Voice Library voices return 402 paid_plan_required).
# Examples (premade): Rachel 21m00Tcm4TlvDq8ikWAM · Adam pNInz6obpgDQGcFmaJgB · Antoni ErXwobaYiN019PkySvjV
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
# Optional Hindi listen (same premade multilingual voice is OK): requires GEMINI_API_KEY to translate brief → Hindi text
# ELEVENLABS_VOICE_ID_HI=21m00Tcm4TlvDq8ikWAM
# ELEVENLABS_AGENT_ID=   # https://elevenlabs.io/app/agents
# WebRTC region (token + LiveKit must match). Use eu-residency or in-residency if your ElevenLabs workspace is in EU/India.
# ELEVENLABS_SERVER_LOCATION=us
# Optional: ConvAI token fetch timeout ms (default 25000; increase only if connections are slow, not if blocked)
# ELEVENLABS_FETCH_TIMEOUT_MS=25000
# Browser mic Q&A (Listen modal “Tap to ask…”) only needs API_KEY + VOICE_ID + GEMINI_API_KEY — no agent.
# Optional ConvAI agent (Talk to ElevenLabs agent) — Tools → add Client tool:
#   Name: gitlore_code_story_answer
#   Description (suggested): "Call for questions about this code line's PR, decision, or impact. Pass the user's question."
# Optional: if the UI asks for a parameters JSON schema, paste one line:
#   {"type":"object","properties":{"user_question":{"type":"string","description":"The user's question about the code story"}},"required":["user_question"]}
# Requires GEMINI_API_KEY for answers via POST /api/voice/gemini-voice-reply
# Optional TTS model (default eleven_turbo_v2_5)
# ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5

# ArmorIQ / ArmorClaw (local policy is default; cloud SDK optional)
# GITLORE_ARMOR_AGENT_CHAT=0   # omit or non-zero: Gemini plan + per-tool enforcement for Overview chat
# ARMORIQ_API_KEY=             # future: @armoriq/armoriq-sdk-customer-ts IAP signing
# ARMORIQ_IAP_ENDPOINT=https://customer-iap.armoriq.ai
# ARMORIQ_PROXY_ENDPOINT=https://customer-proxy.armoriq.ai
# ARMORIQ_BACKEND_ENDPOINT=https://customer-api.armoriq.ai
