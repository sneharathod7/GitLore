# Gemini API (required for knowledge-graph chat synthesis and PR extraction)
GEMINI_API_KEY=your_gemini_api_key
# Text generation default: extraction, narratives, explanations, and chat (free tier: gemini-2.5-flash-lite)
# GEMINI_GENERATION_MODEL=gemini-2.5-flash-lite
# Optional: override only the knowledge-graph chat endpoint
# GEMINI_CHAT_MODEL=gemini-2.5-flash-lite
# Optional: comma-separated fallbacks when chat hits 429 (separate per-model quotas on free tier)
# GEMINI_CHAT_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash
# Embeddings for ingest + chat vector tier (comma-separated). Default tries text-embedding-004, embedding-001, gemini-embedding-001 (v1 API compatibility).
# Atlas vector index numDimensions must match the model output (often 768 — set in Atlas UI).
# GEMINI_EMBEDDING_MODELS=text-embedding-004,embedding-001

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gitlore

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Use frontend origin when Vite proxies /auth (pnpm run dev on port 8080):
GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
# Optional explicit redirect target; otherwise derived from GITHUB_CALLBACK_URL origin:
# FRONTEND_URL=http://localhost:8080

# Session
SESSION_SECRET=your_random_64_char_secret_string_here

# Server
PORT=3001
NODE_ENV=development

# CORS (browser + credentials) — comma-separated origins; must include your Vite dev URL
# CORS_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# Optional - for fallback
GITHUB_PAT=your_github_personal_access_token
