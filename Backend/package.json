{
  "name": "gitlore-api",
  "version": "1.0.0",
  "description": "GitLore Backend - Code Context API",
  "main": "dist/server.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx --watch src/server.ts",
    "test": "node test-backend.js",
    "test:full": "node test-full.js",
    "build": "tsc",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "seed": "tsx src/scripts/seed-patterns.ts"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "@hono/node-server": "^1.0.0",
    "@octokit/graphql": "^7.0.0",
    "dotenv": "^16.3.1",
    "hono": "^4.0.0",
    "mongodb": "^6.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
